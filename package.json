{
  "name": "@murmr/sdk",
  "version": "0.2.0",
  "description": "Official Node.js SDK for the murmr TTS API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "tts",
    "text-to-speech",
    "murmr",
    "voice",
    "audio",
    "ai"
  ],
  "license": "MIT",
  "homepage": "https://murmr.dev/en/docs/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christi4nity/murmr-sdk.git"
  }
}
